7Li(d,p) g.s with DA1p+Delaroche OMP;
NAMELIST
 &FRESCO 
 	 hcm=0.10 rmatch=30.0 rintp=0.1
 	 hnl=0.10 rnl=4.50 centre=0.0
	 jtmin=0.0 jtmax=40 absend=-1
	 thmin=3.00 thmax=-180.00 thinc=1.00
	 ! inh=2 for zero-range ONLY, if not 0
	 it0=1 iter=1 iblock=0 nnu=48 inh=2
	 chans=1 listcc=0 treneg=0 cdetr=0 smats=2 xstabl=1 
	 elab(1)=14.53114 / ! 7.5 AMeV for 7Li but here is for deuton

 &PARTITION namep='d' massp=2.0135532 zp=1 nex=1 namet='Li7' masst=7.01437 zt=3 qval=-0.000 nex=1  /
 &STATES jp=1 bandp=1 ep=0.0000 kkp=0 cpot=1 jt=1.5 bandt=-1 kkt=0 et=0.0000  /
 
 &PARTITION namep='p' massp=1.0072765 zp=1 nex=1 namet='Li8' masst=8.0208405 zt=3 qval=-0.19194317/
 &STATES jp=0.5 bandp=1 ep=0.0000 kkp=0 cpot=2 jt=2 bandt=+1 kkt=0 et=0/ ! l = 1 g.s.
 &partition /
 
 ! Li8 + p OMP KD 12.491677
 &POT kp=1 at=8.0000 rc=1.77831 / !Coulomb term
 &POT kp=1 type=1 p1=58.1316 p2=1.1012 p3=0.67661 p4=0.621506 p5=1.1012 p6=0.67661  / !Volume term
 &POT kp=1 type=2 p1=0 p2=0 p3=0 p4=9.21414 p5=1.3107 p6=0.522864 / !Surface term
 &POT kp=1 type=3 p1=5.58714 p2=0.8619 p3=0.59 p4=-0.0290542 p5=0.8619 p6=0.59 / !SO term

 !Reid soft core potential T=0 for deuteron overlap (composite d, core p)
 &POT kp=2 at=1 rc=1.25  / !Standard coulomb term
 &POT kp=2 type=1 shape=5 p(1:3)= 1.0 0.000 1.0 / ! Volume
 &POT kp=2 type=3 shape=5 p(1:3)= 1.0 0.000 1.0 / ! SO Projectile
 &POT kp=2 type=4 shape=5 p(1:3)= 1.0 0.000 1.0 / ! SO target
 &POT kp=2 type=7 shape=5 p(1:3)= 1.0 0.000 1.0 / ! n-p tensor force

 !Ovelap potential for heavy (composite 8Li, core 7Li)
 &POT kp=3 at=7 rc=1.25 / !Standard coulomb term for core
 &POT kp=3 type=1 p(1:3)= 50 1.25 0.65 /
 &POT kp=3 type=3 p(1:3)= 6 1.1 0.65 /

 ! Adiabatic from fort.4
 !Coulomb
 &POT kp=4 at=7.0000 rc=1.3  / 
 ! Read volume real
 &POT kp=4 type=1 shape=7 p(1:1)= 1.0 /
 ! Read volume imaginary
 &POT kp=4 type=1 shape=8 p(1:2)= 0.0 1.0 /
 ! Read SO real
 &POT kp=4 type=3 shape=7 p(1:1)= 0.5 /
 ! Read SO imaginary
 &POT kp=4 type=3 shape=8 p(1:2)= 0 0.5 /
 
 &POT / 

! how d can be decomposed in p+n <d|p+n>
! Form factor of deuteron 
&OVERLAP kn1=1 kn2=2 ic1=2 ic2=1 in=-1 kind=3 nn=1 l=0 lmax=2 sn=0.5 j=0.5 kbpot=2 be=2.224 isc=0 ipc=4 nfl=0 nam=0 ampl=0.0 /
! Form factor of 7Li + n
&OVERLAP kn1=3 kn2=3 ic1=1 ic2=2 in=2 kind=0 nn=1 l=1 sn=0.5 j=1.5 kbpot=3 be=2.0326975 isc=1 ipc=4 nfl=0 nam=0 ampl=0.0 /

 &OVERLAP / 

! Specify type of coupling 
&COUPLING icto=-2 icfrom=1 kind=5 ip1=0 ip2=0 ip3=0 p1=125.19 p2=0 /
! Projectile coupling
&cfp in=1 ib=1 ia=1 kn=1 a=1.0 /
! Lithium coupling
&cfp in=-2 ib=1 ia=1 kn=3 a=1.0 /

 &COUPLING / 

